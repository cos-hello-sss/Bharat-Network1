// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() { return request.auth != null; }
    function isUser(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    function isNetworkMember(networkId) {
      return isAuth() && request.auth.uid in get(/databases/$(database)/documents/networks/$(networkId)).data.members;
    }
    function isNetworkOwner(networkId) {
      return isAuth() && get(/databases/$(database)/documents/networks/$(networkId)).data.ownerId == request.auth.uid;
    }
    function isNetworkModerator(networkId) {
      return isAuth() && (
        request.auth.uid in get(/databases/$(database)/documents/networks/$(networkId)).data.moderators ||
        isNetworkOwner(networkId) ||
        isAdmin()
      );
    }

    // Users collection
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isUser(uid);
      allow update: if isUser(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin'])
                   || isAdmin();
    }

    // Networks collection
    match /networks/{networkId} {
      allow read: if resource.data.isPublic == true || isNetworkMember(networkId) || isAdmin();
      allow create: if isAuth();
      allow update: if isNetworkOwner(networkId) || isAdmin();
      allow delete: if isNetworkOwner(networkId) || isAdmin();

      // Chatrooms subcollection
      match /chatrooms/{chatroomId} {
        allow read: if isNetworkMember(networkId) || isAdmin();
        allow create, delete: if isNetworkModerator(networkId);

        // Messages subcollection
        match /messages/{messageId} {
          allow read: if isNetworkMember(networkId) || isAdmin();
          allow create: if isNetworkMember(networkId) && request.resource.data.uid == request.auth.uid;
          allow delete: if isNetworkModerator(networkId);
        }
      }

      // Meetings subcollection
      match /meetings/{meetingId} {
        allow read: if isNetworkMember(networkId) || isAdmin();
        allow create, delete: if isNetworkModerator(networkId);
        allow update: if isNetworkMember(networkId) || isAdmin(); // for RSVP
      }

      // Fact checks subcollection
      match /factchecks/{factId} {
        allow read: if isNetworkMember(networkId) || isAdmin();
        allow create: if isNetworkMember(networkId);
        allow update: if isNetworkMember(networkId) || isAdmin(); // for voting
        allow delete: if isNetworkModerator(networkId);
      }
    }
  }
}
